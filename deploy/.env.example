# Database connection string (PostgreSQL)
DATABASE_URL=postgres://votinguser:votingpass@postgres:5432/votingdb?sslmode=disable

# Redis connection string
REDIS_URL=redis://redis:6379/0

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# JWT token TTLs (Go duration format)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# How often to recompute the trending ZSET (e.g., 1m, 5m)
TRENDING_RECOMPUTE_INTERVAL=2m

# Server listen port
PORT=8080
